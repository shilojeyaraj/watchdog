{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "migrate": "node migrations/run-migrations.js",
    "migrate:status": "node -e \"const {Client}=require('pg');require('dotenv').config({path:'.env.local'});(async()=>{const c=new Client({connectionString:process.env.DATABASE_URL});await c.connect();const r=await c.query('SELECT version,applied_at FROM schema_migrations ORDER BY applied_at');console.log('Applied migrations:',r.rows.length===0?'None':r.rows.map(x=>x.version).join(', '));await c.end();})()\"",
    "db:test": "node scripts/test-db-connection.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:danger": "node scripts/test-danger-detection.js",
    "test:danger:direct": "node scripts/test-danger-detection-direct.js"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.36.10",
    "@neondatabase/serverless": "^1.0.2",
    "@overshoot/sdk": "^0.1.0-alpha.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "body-parser": "^2.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "framer-motion": "^12.35.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "next": "16.1.3",
    "pg": "^8.17.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "svix": "^1.84.1",
    "tailwind-merge": "^3.5.0",
    "twilio": "^5.11.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
}
